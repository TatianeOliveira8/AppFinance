# API Configuration
# =====================
# Altere este valor para o IP da sua máquina ou servidor onde o backend está rodando

# Para desenvolvimento local (mesma máquina):
# REACT_APP_API_URL=http://192.168.15.12:8000/api

# Para emulador Android no mesmo PC:
# REACT_APP_API_URL=http://10.0.2.2:8000/api

# Para usar em produção:
# REACT_APP_API_URL=https://seu-servidor.com/api

REACT_APP_API_URL=http://localhost:8000/api
